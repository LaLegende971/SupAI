[Unit]
Description=SupAI Backend API
After=network.target

[Service]
Type=simple
User=supai-root
WorkingDirectory=/opt/supai/backend
ExecStart=/opt/supai/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 5001
Restart=on-failure
RestartSec=3
StartLimitIntervalSec=60
StartLimitBurst=3
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
